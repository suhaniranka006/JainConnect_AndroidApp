<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="6dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Event Banner Image -->
        <ImageView
            android:id="@+id/ivEventImage"
            android:layout_width="0dp"
            android:layout_height="150dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_launcher_background"
            android:visibility="visible"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginBottom="12dp"/>

        <!-- Date Box (Left Side) - Below Image -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardDateBox"
            android:layout_width="60dp"
            android:layout_height="70dp"
            app:cardBackgroundColor="#FFE0B2"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            android:layout_marginTop="12dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivEventImage">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvDateDay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="25"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#E64A19"/>

                <TextView
                    android:id="@+id/tvDateMonth"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DEC"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#E64A19"
                    android:textAllCaps="true"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Vertical Divider -->
        <View
            android:id="@+id/viewDivider"
            android:layout_width="1dp"
            android:layout_height="0dp"
            android:background="#EEE"
            android:layout_marginStart="12dp"
            app:layout_constraintStart_toEndOf="@id/cardDateBox"
            app:layout_constraintTop_toTopOf="@id/cardDateBox"
            app:layout_constraintBottom_toBottomOf="@id/cardDateBox"/>

        <!-- Event Details (Right Side) -->
        <LinearLayout
            android:id="@+id/layoutDetails"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            app:layout_constraintStart_toEndOf="@id/viewDivider"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/cardDateBox">

            <TextView
                android:id="@+id/tvEventName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:text="Community Meetup"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:ellipsize="end"
                android:maxLines="2"/>

            <!-- Location Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical">
                
                <ImageView
                     android:layout_width="14dp"
                     android:layout_height="14dp"
                     android:src="@drawable/ic_location"
                     app:tint="#757575"/>
                
                <TextView
                    android:id="@+id/tvEventLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="Mumbai"
                    android:textSize="13sp"
                    android:textColor="#616161"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginStart="6dp"/>
            </LinearLayout>

            <!-- Time Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical">

                <ImageView
                     android:layout_width="14dp"
                     android:layout_height="14dp"
                     android:src="@drawable/ic_time"
                     app:tint="#757575"/>

                <TextView
                     android:id="@+id/tvEventTime"
                     android:layout_width="wrap_content"
                     android:layout_height="wrap_content"
                     tools:text="10:00 AM"
                     android:textSize="13sp"
                     android:textColor="#616161"
                     android:layout_marginStart="6dp"/>
            </LinearLayout>
            
             <TextView
                android:id="@+id/tvEventDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                tools:text="Join us for a spiritual gathering..."
                android:textSize="13sp"
                android:textColor="#616161"
                android:layout_marginTop="4dp"
                android:maxLines="2"
                android:ellipsize="end"/>

             <!-- Hidden views for compatibility if adapter references them directly -->
             <TextView android:id="@+id/tvEventDateTime" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>
             <TextView android:id="@+id/tvEventContact" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone"/>

        </LinearLayout>

        <!-- Horizontal Divider -->
        <View
            android:id="@+id/viewHDivider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEE"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/layoutDetails"/>

        <!-- RSVP Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/viewHDivider">

             <TextView
                android:id="@+id/tvRsvpCount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                tools:text="12 Going"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/bright_saffron"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRsvp"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Join"
                android:textColor="@color/bright_saffron"
                android:textStyle="bold"
                android:paddingHorizontal="16dp"
                app:strokeColor="@color/bright_saffron"
                app:strokeWidth="1dp"
                app:cornerRadius="18dp"/>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
