<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top Section: Image + Details -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp">

            <!-- Event Image (Left) -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivEventImage"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_launcher_background"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.MediumComponent"/>

            <!-- Details (Right) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp"
                android:gravity="center_vertical">

                <!-- Name -->
                <TextView
                    android:id="@+id/tvEventName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    tools:text="Event Name Here"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:layout_marginBottom="4dp"/>

                <!-- Location -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="2dp">
                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_location"
                        app:tint="#757575"/>
                    <TextView
                        android:id="@+id/tvEventLocation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="Location"
                        android:textSize="13sp"
                        android:textColor="#616161"
                        android:layout_marginStart="6dp"
                        android:maxLines="1"
                        android:ellipsize="end"/>
                </LinearLayout>

                <!-- Date -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="2dp">
                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_time"
                        app:tint="#757575"/>
                    <TextView
                        android:id="@+id/tvEventDateLinear"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="Start Date"
                        android:textSize="13sp"
                        android:textColor="#E64A19"
                        android:layout_marginStart="6dp"/>
                </LinearLayout>

                <!-- Time -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_time"
                        app:tint="#616161"/> <!-- Or a clock icon diff tint -->
                    <TextView
                        android:id="@+id/tvEventTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="10:00 AM"
                        android:textSize="13sp"
                        android:textColor="#616161"
                        android:layout_marginStart="6dp"/>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F5F5F5"/>

        <!-- Bottom Section: RSVP -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp">



            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvRsvpCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="12 Going"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#E64A19"/>

                <TextView
                    android:id="@+id/tvDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="5.2 km away"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#E64A19"
                    android:visibility="gone"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp"
                    android:drawablePadding="4dp"
                    android:drawableStart="@drawable/ic_location"
                    app:drawableTint="#E64A19"/>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRsvp"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="JOIN"
                android:textSize="12sp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="#E64A19"
                android:textColor="#E64A19"
                android:paddingHorizontal="16dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>

            <ImageView
                android:id="@+id/btnSave"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:padding="8dp"
                android:src="@drawable/ic_bookmark_border"
                app:tint="#757575"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvPostDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            tools:text="Posted on 12 Dec, 10:00 AM"
            android:textSize="10sp"
            android:textColor="#9E9E9E"
            android:gravity="end"
            android:paddingHorizontal="12dp"
            android:paddingBottom="8dp"/>

        <!-- Hidden Views for Adapter Compatibility -->
         <TextView
            android:id="@+id/tvDateDay"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"/>
        <TextView
            android:id="@+id/tvDateMonth"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"/>
        <TextView
            android:id="@+id/tvEventDescription"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
