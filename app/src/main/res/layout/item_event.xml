<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/saffron_dark"
    app:strokeWidth="1.5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="?android:attr/selectableItemBackground">

        <TextView
            android:id="@+id/tvEventName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#212121"
            tools:text="Paryushan Parv"/>

        <TextView
            android:id="@+id/tvEventDateTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#757575"
            tools:text="2025-11-10"
            android:layout_marginTop="4dp"/>

        <TextView
            android:id="@+id/tvEventTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#757575"
            tools:text="09:00 AM"
            android:layout_marginTop="4dp"/>

        <TextView
            android:id="@+id/tvEventLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#757575"
            tools:text="Udaipur"
            android:layout_marginTop="2dp"/>

        <TextView
            android:id="@+id/tvEventDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#424242"
            tools:text="Annual 8-day period of fasting and prayer."
            android:layout_marginTop="8dp"
            android:visibility="visible"
         android:maxLines="3"
         android:ellipsize="end"/>

        <!-- === YEH NAYA SECTION ADD KIYA GAYA HAI === -->

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/tvRsvpCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:textColor="@color/saffron_dark"
                android:textStyle="bold"
                tools:text="15 people are going" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRsvp"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="I'm Going"
                android:textColor="@color/saffron_dark"
                app:strokeColor="@color/saffron_dark"
                app:cornerRadius="20dp"
                android:paddingVertical="8dp"
                android:paddingHorizontal="16dp"
                android:textAllCaps="false"/>

        </RelativeLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>