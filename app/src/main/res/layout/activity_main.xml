<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    tools:context=".ui.activities.MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/_10sdp"
        android:paddingEnd="@dimen/_10sdp"
        android:paddingTop="@dimen/_10sdp">

        <!-- Header Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Profile (P) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnProfile"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                android:text="P"
                android:textColor="@color/saffron_dark"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                app:backgroundTint="@android:color/white"
                app:cornerRadius="24dp"
                app:strokeColor="@android:color/black"
                app:strokeWidth="1.5dp" />

            <!-- Donate (Rupee) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDonate"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="4dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                android:text="₹"
                android:textColor="@color/saffron_dark"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                app:backgroundTint="@android:color/white"
                app:cornerRadius="24dp"
                app:strokeColor="@android:color/black"
                app:strokeWidth="1.5dp" />

            <!-- Title -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="JainConnect"
                android:textColor="@color/saffron_dark"
                android:textSize="22sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Location Toggle -->
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:theme="@style/Theme.MaterialComponents.Light"
                app:thumbTint="@color/saffron_dark"
                app:trackTint="#E0E0E0" />

            <!-- Help (?) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHelp"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                android:text="?"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                app:backgroundTint="@android:color/transparent"
                app:cornerRadius="20dp"
                app:strokeColor="@android:color/black"
                app:strokeWidth="1.5dp" />

            <!-- Menu (=) -->
            <ImageView
                android:id="@+id/btnMenu"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_menu_black"
                app:tint="@color/black" />

        </LinearLayout>

        <View
            android:id="@+id/titleUnderline"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_marginTop="8dp"
            android:background="@color/saffron_dark"
            android:layout_marginBottom="24dp"/>


        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/shimmerDashboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="visible"
            tools:visibility="gone"
            tools:ignore="MissingClass">
            <include layout="@layout/layout_dashboard_shimmer" />
        </com.facebook.shimmer.ShimmerFrameLayout>



        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardGreeting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_40sdp"
            app:cardBackgroundColor="@color/lightest_saffron"
            app:cardCornerRadius="@dimen/_16sdp"
            app:cardElevation="@dimen/_4sdp"
            android:visibility="invisible"
            tools:visibility="visible">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/_16sdp">

                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="JAI JINENDRA SUHANI!"
                    android:textColor="@color/black"
                    android:textSize="@dimen/_18ssp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvCurrentTithi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Today is ASHTAMI"
                    android:textColor="@color/black"
                    android:textSize="@dimen/_16ssp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvGreeting" />

                <ImageView
                    android:id="@+id/ivSunrise"
                    android:layout_width="@dimen/_24sdp"
                    android:layout_height="@dimen/_24sdp"
                    android:layout_marginTop="@dimen/_16sdp"
                    android:src="@drawable/ic_sunrise"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvCurrentTithi"
                    app:tint="@null" />

                <TextView
                    android:id="@+id/tvSunriseTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_8sdp"
                    android:text="6:00 AM"
                    android:textColor="@color/black"
                    android:textSize="@dimen/_16ssp"
                    app:layout_constraintBottom_toBottomOf="@id/ivSunrise"
                    app:layout_constraintStart_toEndOf="@id/ivSunrise"
                    app:layout_constraintTop_toTopOf="@id/ivSunrise" />

                <ImageView
                    android:id="@+id/ivSunset"
                    android:layout_width="@dimen/_24sdp"
                    android:layout_height="@dimen/_24sdp"
                    android:layout_marginEnd="@dimen/_8sdp"
                    android:src="@drawable/ic_sunset"
                    app:layout_constraintEnd_toStartOf="@id/tvSunsetTime"
                    app:layout_constraintTop_toTopOf="@id/ivSunrise"
                    app:tint="@null" />

                <TextView
                    android:id="@+id/tvSunsetTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="6:00 PM"
                    android:textColor="@color/black"
                    android:textSize="@dimen/_16ssp"
                    app:layout_constraintBottom_toBottomOf="@id/ivSunset"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/ivSunset" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_35sdp"
            android:columnCount="2"
            android:layout_marginBottom="@dimen/_20sdp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTithi"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/_8sdp"
                android:backgroundTint="@color/card_background"
                android:paddingTop="@dimen/_20sdp"
                android:paddingBottom="@dimen/_20sdp"
                android:text="TITHI"
                android:textAllCaps="true"
                android:textColor="@color/black"
                android:textStyle="bold"
                app:cornerRadius="@dimen/_16sdp"
                app:icon="@drawable/ic_tithi"
                app:iconGravity="textTop"
                app:iconPadding="@dimen/_8sdp"
                app:iconSize="@dimen/_36sdp"
                app:iconTint="@null"
                app:strokeColor="@color/saffron_dark"
                app:strokeWidth="@dimen/_1sdp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHorizons"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/_8sdp"
                android:backgroundTint="@color/card_background"
                android:paddingTop="@dimen/_20sdp"
                android:paddingBottom="@dimen/_20sdp"
                android:text="HORIZONS"
                android:textAllCaps="true"
                android:textColor="@color/black"
                android:textStyle="bold"
                app:cornerRadius="@dimen/_16sdp"
                app:icon="@drawable/ic_horizons"
                app:iconGravity="textTop"
                app:iconPadding="@dimen/_8sdp"
                app:iconSize="@dimen/_36sdp"
                app:iconTint="@null"
                app:strokeColor="@color/saffron_dark"
                app:strokeWidth="@dimen/_1sdp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEvents"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/_8sdp"
                android:backgroundTint="@color/card_background"
                android:paddingTop="@dimen/_20sdp"
                android:paddingBottom="@dimen/_20sdp"
                android:text="EVENTS"
                android:textAllCaps="true"
                android:textColor="@color/black"
                android:textStyle="bold"
                app:cornerRadius="@dimen/_16sdp"
                app:icon="@drawable/ic_events"
                app:iconGravity="textTop"
                app:iconPadding="@dimen/_8sdp"
                app:iconSize="@dimen/_36sdp"
                app:iconTint="@null"
                app:strokeColor="@color/saffron_dark"
                app:strokeWidth="@dimen/_1sdp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMonks"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/_8sdp"
                android:backgroundTint="@color/card_background"
                android:paddingTop="@dimen/_20sdp"
                android:paddingBottom="@dimen/_20sdp"
                android:text="MONKS"
                android:textAllCaps="true"
                android:textColor="@color/black"
                android:textStyle="bold"
                app:cornerRadius="@dimen/_16sdp"
                app:icon="@drawable/ic_monks"
                app:iconGravity="textTop"
                app:iconPadding="@dimen/_8sdp"
                app:iconSize="@dimen/_36sdp"
                app:iconTint="@null"
                app:strokeColor="@color/saffron_dark"
                app:strokeWidth="@dimen/_1sdp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMe"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/_8sdp"
                android:backgroundTint="@color/card_background"
                android:paddingTop="@dimen/_20sdp"
                android:paddingBottom="@dimen/_20sdp"
                android:text="ME"
                android:textAllCaps="true"
                android:textColor="@color/black"
                android:textStyle="bold"
                app:cornerRadius="@dimen/_16sdp"
                app:icon="@drawable/ic_me"
                app:iconGravity="textTop"
                app:iconPadding="@dimen/_8sdp"
                app:iconSize="@dimen/_36sdp"
                app:iconTint="@null"
                app:strokeColor="@color/saffron_dark"
                app:strokeWidth="@dimen/_1sdp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContact"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/_8sdp"
                android:backgroundTint="@color/card_background"
                android:paddingTop="@dimen/_20sdp"
                android:paddingBottom="@dimen/_20sdp"
                android:text="CONTACT"
                android:textAllCaps="true"
                android:textColor="@color/black"
                android:textStyle="bold"
                app:cornerRadius="@dimen/_16sdp"
                app:icon="@drawable/ic_contact"
                app:iconGravity="textTop"
                app:iconPadding="@dimen/_8sdp"
                app:iconSize="@dimen/_36sdp"
                app:iconTint="@null"
                app:strokeColor="@color/saffron_dark"
                app:strokeWidth="@dimen/_1sdp" />
        </GridLayout>
    </LinearLayout>
</ScrollView>