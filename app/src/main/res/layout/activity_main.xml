<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    tools:context=".ui.activities.MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/_10sdp"
        android:paddingEnd="@dimen/_10sdp"
        android:paddingTop="@dimen/_10sdp">

        <!-- Header Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Profile (P) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnProfile"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                android:text="P"
                android:textColor="@color/saffron_dark"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                app:backgroundTint="@android:color/white"
                app:cornerRadius="24dp"
                app:strokeColor="@android:color/black"
                app:strokeWidth="1.5dp" />

            <!-- Donate (Rupee) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDonate"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="4dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                android:text="₹"
                android:textColor="@color/saffron_dark"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                app:backgroundTint="@android:color/white"
                app:cornerRadius="24dp"
                app:strokeColor="@android:color/black"
                app:strokeWidth="1.5dp" />

            <!-- Title -->
            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="JainConnect"
                android:textColor="@color/saffron_dark"
                android:textSize="22sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Location Toggle -->
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:theme="@style/Theme.MaterialComponents.Light"
                app:thumbTint="@color/saffron_dark"
                app:trackTint="#E0E0E0" />

            <!-- Help (?) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHelp"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="4dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:padding="0dp"
                android:text="?"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                app:backgroundTint="@android:color/transparent"
                app:cornerRadius="20dp"
                app:strokeColor="@android:color/black"
                app:strokeWidth="1.5dp" />

            <!-- Menu (=) -->
            <ImageView
                android:id="@+id/btnMenu"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_menu_black"
                app:tint="@color/black" />

        </LinearLayout>

        <View
            android:id="@+id/titleUnderline"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_marginTop="8dp"
            android:background="@color/saffron_dark"
            android:layout_marginBottom="24dp"/>


        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/shimmerDashboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="visible"
            tools:visibility="gone"
            tools:ignore="MissingClass">
            <include layout="@layout/layout_dashboard_shimmer" />
        </com.facebook.shimmer.ShimmerFrameLayout>



        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardGreeting"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/lightest_saffron"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:visibility="invisible"
            tools:visibility="visible">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <!-- Row 1: Today (Left) | Greeting (Right) -->
                <TextView
                    android:id="@+id/tvLabelToday"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Today"
                    android:textColor="@android:color/black"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Jai Jinendra Suhani"
                    android:textColor="@color/saffron_dark"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="end"
                    android:layout_marginStart="8dp"
                    app:layout_constraintStart_toEndOf="@id/tvLabelToday"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Row 2: Date -->
                <TextView
                    android:id="@+id/tvDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Monday, 15-12-25"
                    android:textColor="@android:color/black"
                    android:textSize="16sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvLabelToday" />

                <!-- Row 3: Tithi (Left) | Location (Right) -->
                <TextView
                    android:id="@+id/tvTithiName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Ekadashi"
                    android:textColor="@color/saffron_dark"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvDate" />

                <LinearLayout
                    android:id="@+id/layoutLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBottom_toBottomOf="@id/tvTithiName"
                    app:layout_constraintTop_toTopOf="@id/tvTithiName">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_location"
                        app:tint="@color/black" />

                    <TextView
                        android:id="@+id/tvLocationName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:text="Location"
                        android:textColor="@android:color/black"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- Row 4: Sunrise (Left) | Sunset (Right) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="24dp"
                    app:layout_constraintTop_toBottomOf="@id/tvTithiName"
                    app:layout_constraintBottom_toBottomOf="parent">

                    <!-- Sunrise -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical|start">
                        <ImageView
                            android:id="@+id/ivSunrise"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_sunrise" />
                        <TextView
                            android:id="@+id/tvSunriseTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Sunrise"
                            android:textColor="@android:color/black"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <!-- Sunset -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical|end">
                        <ImageView
                            android:id="@+id/ivSunset"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_sunset" />
                        <TextView
                            android:id="@+id/tvSunsetTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Sunset"
                            android:textColor="@android:color/black"
                            android:textSize="16sp" />
                    </LinearLayout>
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_35sdp"
            android:columnCount="2"
            android:layout_marginBottom="@dimen/_20sdp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTithi"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/_8sdp"
                android:backgroundTint="@color/card_background"
                android:paddingTop="@dimen/_20sdp"
                android:paddingBottom="@dimen/_20sdp"
                android:text="TITHI"
                android:textAllCaps="true"
                android:textColor="@color/black"
                android:textStyle="bold"
                app:cornerRadius="@dimen/_16sdp"
                app:icon="@drawable/ic_tithi"
                app:iconGravity="textTop"
                app:iconPadding="@dimen/_8sdp"
                app:iconSize="@dimen/_36sdp"
                app:iconTint="@null"
                app:strokeColor="@color/saffron_dark"
                app:strokeWidth="@dimen/_1sdp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHorizons"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/_8sdp"
                android:backgroundTint="@color/card_background"
                android:paddingTop="@dimen/_20sdp"
                android:paddingBottom="@dimen/_20sdp"
                android:text="HORIZONS"
                android:textAllCaps="true"
                android:textColor="@color/black"
                android:textStyle="bold"
                app:cornerRadius="@dimen/_16sdp"
                app:icon="@drawable/ic_horizons"
                app:iconGravity="textTop"
                app:iconPadding="@dimen/_8sdp"
                app:iconSize="@dimen/_36sdp"
                app:iconTint="@null"
                app:strokeColor="@color/saffron_dark"
                app:strokeWidth="@dimen/_1sdp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEvents"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/_8sdp"
                android:backgroundTint="@color/card_background"
                android:paddingTop="@dimen/_20sdp"
                android:paddingBottom="@dimen/_20sdp"
                android:text="EVENTS"
                android:textAllCaps="true"
                android:textColor="@color/black"
                android:textStyle="bold"
                app:cornerRadius="@dimen/_16sdp"
                app:icon="@drawable/ic_events"
                app:iconGravity="textTop"
                app:iconPadding="@dimen/_8sdp"
                app:iconSize="@dimen/_36sdp"
                app:iconTint="@null"
                app:strokeColor="@color/saffron_dark"
                app:strokeWidth="@dimen/_1sdp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMonks"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/_8sdp"
                android:backgroundTint="@color/card_background"
                android:paddingTop="@dimen/_20sdp"
                android:paddingBottom="@dimen/_20sdp"
                android:text="MONKS"
                android:textAllCaps="true"
                android:textColor="@color/black"
                android:textStyle="bold"
                app:cornerRadius="@dimen/_16sdp"
                app:icon="@drawable/ic_monks"
                app:iconGravity="textTop"
                app:iconPadding="@dimen/_8sdp"
                app:iconSize="@dimen/_36sdp"
                app:iconTint="@null"
                app:strokeColor="@color/saffron_dark"
                app:strokeWidth="@dimen/_1sdp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMe"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/_8sdp"
                android:backgroundTint="@color/card_background"
                android:paddingTop="@dimen/_20sdp"
                android:paddingBottom="@dimen/_20sdp"
                android:text="ME"
                android:textAllCaps="true"
                android:textColor="@color/black"
                android:textStyle="bold"
                app:cornerRadius="@dimen/_16sdp"
                app:icon="@drawable/ic_me"
                app:iconGravity="textTop"
                app:iconPadding="@dimen/_8sdp"
                app:iconSize="@dimen/_36sdp"
                app:iconTint="@null"
                app:strokeColor="@color/saffron_dark"
                app:strokeWidth="@dimen/_1sdp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContact"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/_8sdp"
                android:backgroundTint="@color/card_background"
                android:paddingTop="@dimen/_20sdp"
                android:paddingBottom="@dimen/_20sdp"
                android:text="CONTACT"
                android:textAllCaps="true"
                android:textColor="@color/black"
                android:textStyle="bold"
                app:cornerRadius="@dimen/_16sdp"
                app:icon="@drawable/ic_contact"
                app:iconGravity="textTop"
                app:iconPadding="@dimen/_8sdp"
                app:iconSize="@dimen/_36sdp"
                app:iconTint="@null"
                app:strokeColor="@color/saffron_dark"
                app:strokeWidth="@dimen/_1sdp" />
        </GridLayout>
    </LinearLayout>
</ScrollView>