<?xml version="1.0" encoding="utf-8"?>

<!--
scroll view is used to ensure it content is too tall for small phone screen , then user can scroll down to see all buttons
-->

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    tools:context=".ui.activities.MainActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/_20sdp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_marginTop="@dimen/_20sdp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="JAINCONNECT"
            android:textColor="@color/saffron_dark"
            android:textSize="@dimen/_35ssp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


        <!-- view is used for line
        -->
        <View
            android:id="@+id/titleUnderline"
            android:layout_width="0dp"
            android:layout_height="@dimen/_2sdp"
            android:background="@color/saffron_dark"
            app:layout_constraintEnd_toEndOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="@id/tvTitle"
            app:layout_constraintTop_toBottomOf="@id/tvTitle" />

        <!-- Shimmer Container -->
        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/shimmerDashboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/titleUnderline"
            android:visibility="visible"
            tools:visibility="visible">
            <include layout="@layout/layout_dashboard_shimmer" />
        </com.facebook.shimmer.ShimmerFrameLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardGreeting"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_40sdp"
            app:cardBackgroundColor="@color/lightest_saffron"
            app:cardCornerRadius="@dimen/_16sdp"
            app:cardElevation="@dimen/_4sdp"
            android:visibility="invisible"

            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/titleUnderline">


            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/_16sdp">

                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="JAI JINENDRA SUHANI!"
                    android:textColor="@color/black"
                    android:textSize="@dimen/_18ssp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvCurrentTithi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Today is ASHTAMI"
                    android:textColor="@color/black"
                    android:textSize="@dimen/_16ssp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvGreeting" />

                <ImageView
                    android:id="@+id/ivSunrise"
                    android:layout_width="@dimen/_24sdp"
                    android:layout_height="@dimen/_24sdp"
                    android:layout_marginTop="@dimen/_16sdp"
                    android:src="@drawable/ic_sunrise"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvCurrentTithi"
                    app:tint="@null" />

                <TextView
                    android:id="@+id/tvSunriseTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/_8sdp"
                    android:text="6:00 AM"
                    android:textColor="@color/black"
                    android:textSize="@dimen/_16ssp"
                    app:layout_constraintBottom_toBottomOf="@id/ivSunrise"
                    app:layout_constraintStart_toEndOf="@id/ivSunrise"
                    app:layout_constraintTop_toTopOf="@id/ivSunrise" />

                <ImageView
                    android:id="@+id/ivSunset"
                    android:layout_width="@dimen/_24sdp"
                    android:layout_height="@dimen/_24sdp"
                    android:layout_marginEnd="@dimen/_8sdp"
                    android:src="@drawable/ic_sunset"
                    app:layout_constraintEnd_toStartOf="@id/tvSunsetTime"
                    app:layout_constraintTop_toTopOf="@id/ivSunrise"
                    app:tint="@null" />

                <TextView
                    android:id="@+id/tvSunsetTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="6:00 PM"
                    android:textColor="@color/black"
                    android:textSize="@dimen/_16ssp"
                    app:layout_constraintBottom_toBottomOf="@id/ivSunset"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/ivSunset" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <GridLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_35sdp"
            android:columnCount="2"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardGreeting">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTithi"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/_8sdp"
                android:backgroundTint="@color/card_background"
                android:paddingTop="@dimen/_20sdp"
                android:paddingBottom="@dimen/_20sdp"
                android:text="TITHI"
                android:textAllCaps="true"
                android:textColor="@color/black"
                android:textStyle="bold"
                app:cornerRadius="@dimen/_16sdp"
                app:icon="@drawable/ic_tithi"
                app:iconGravity="textTop"
                app:iconPadding="@dimen/_8sdp"

                app:iconSize="@dimen/_36sdp"
                app:iconTint="@null"
                app:strokeColor="@color/saffron_dark"
                app:strokeWidth="@dimen/_1sdp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHorizons"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/_8sdp"
                android:backgroundTint="@color/card_background"
                android:paddingTop="@dimen/_20sdp"
                android:paddingBottom="@dimen/_20sdp"
                android:text="HORIZONS"
                android:textAllCaps="true"
                android:textColor="@color/black"
                android:textStyle="bold"
                app:cornerRadius="@dimen/_16sdp"
                app:icon="@drawable/ic_horizons"
                app:iconGravity="textTop"
                app:iconPadding="@dimen/_8sdp"

                app:iconSize="@dimen/_36sdp"
                app:iconTint="@null"
                app:strokeColor="@color/saffron_dark"
                app:strokeWidth="@dimen/_1sdp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEvents"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/_8sdp"
                android:backgroundTint="@color/card_background"
                android:paddingTop="@dimen/_20sdp"
                android:paddingBottom="@dimen/_20sdp"
                android:text="EVENTS"
                android:textAllCaps="true"
                android:textColor="@color/black"
                android:textStyle="bold"
                app:cornerRadius="@dimen/_16sdp"
                app:icon="@drawable/ic_events"
                app:iconGravity="textTop"
                app:iconPadding="@dimen/_8sdp"

                app:iconSize="@dimen/_36sdp"
                app:iconTint="@null"
                app:strokeColor="@color/saffron_dark"
                app:strokeWidth="@dimen/_1sdp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMonks"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/_8sdp"
                android:backgroundTint="@color/card_background"
                android:paddingTop="@dimen/_20sdp"
                android:paddingBottom="@dimen/_20sdp"
                android:text="MONKS"
                android:textAllCaps="true"
                android:textColor="@color/black"
                android:textStyle="bold"
                app:cornerRadius="@dimen/_16sdp"
                app:icon="@drawable/ic_monks"
                app:iconGravity="textTop"
                app:iconPadding="@dimen/_8sdp"

                app:iconSize="@dimen/_36sdp"
                app:iconTint="@null"
                app:strokeColor="@color/saffron_dark"
                app:strokeWidth="@dimen/_1sdp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMe"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/_8sdp"
                android:backgroundTint="@color/card_background"
                android:paddingTop="@dimen/_20sdp"
                android:paddingBottom="@dimen/_20sdp"
                android:text="ME"
                android:textAllCaps="true"
                android:textColor="@color/black"
                android:textStyle="bold"
                app:cornerRadius="@dimen/_16sdp"
                app:icon="@drawable/ic_me"
                app:iconGravity="textTop"
                app:iconPadding="@dimen/_8sdp"

                app:iconSize="@dimen/_36sdp"
                app:iconTint="@null"
                app:strokeColor="@color/saffron_dark"
                app:strokeWidth="@dimen/_1sdp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContact"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="@dimen/_8sdp"
                android:backgroundTint="@color/card_background"
                android:paddingTop="@dimen/_20sdp"
                android:paddingBottom="@dimen/_20sdp"
                android:text="CONTACT"
                android:textAllCaps="true"
                android:textColor="@color/black"
                android:textStyle="bold"
                app:cornerRadius="@dimen/_16sdp"
                app:icon="@drawable/ic_contact"
                app:iconGravity="textTop"
                app:iconPadding="@dimen/_8sdp"

                app:iconSize="@dimen/_36sdp"
                app:iconTint="@null"
                app:strokeColor="@color/saffron_dark"
                app:strokeWidth="@dimen/_1sdp" />
        </GridLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
