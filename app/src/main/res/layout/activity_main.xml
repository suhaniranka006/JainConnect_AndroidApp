<?xml version="1.0" encoding="utf-8"?>

<!--
scroll view is used to ensure it content is too tall for small phone screen , then user can scroll down to see all buttons
-->

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/saffron_light"
    tools:context=".MainActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_marginTop="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="JAINCONNECT"
            android:textColor="@color/saffron_dark"
            android:textSize="35dp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


        <!-- view is used for line
        -->
        <View
            android:id="@+id/titleUnderline"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:background="@color/saffron_dark"
            app:layout_constraintEnd_toEndOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="@id/tvTitle"
            app:layout_constraintTop_toBottomOf="@id/tvTitle" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardGreeting"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            app:cardBackgroundColor="@color/lightest_saffron"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"

            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/titleUnderline">


            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="128dp"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="JAI JINENDRA SUHANI!"
                    android:textColor="@android:color/black"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvCurrentTithi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Today is ASHTAMI"
                    android:textColor="@android:color/black"
                    android:textSize="16sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvGreeting" />

                <ImageView
                    android:id="@+id/ivSunrise"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginTop="16dp"
                    android:src="@drawable/ic_sunrise"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tvCurrentTithi"
                    app:tint="@null" />

                <TextView
                    android:id="@+id/tvSunriseTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="6:00 AM"
                    android:textColor="@android:color/black"
                    android:textSize="16sp"
                    app:layout_constraintBottom_toBottomOf="@id/ivSunrise"
                    app:layout_constraintStart_toEndOf="@id/ivSunrise"
                    app:layout_constraintTop_toTopOf="@id/ivSunrise" />

                <ImageView
                    android:id="@+id/ivSunset"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="8dp"
                    android:src="@drawable/ic_sunset"
                    app:layout_constraintEnd_toStartOf="@id/tvSunsetTime"
                    app:layout_constraintTop_toTopOf="@id/ivSunrise"
                    app:tint="@null" />

                <TextView
                    android:id="@+id/tvSunsetTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="6:00 PM"
                    android:textColor="@android:color/black"
                    android:textSize="16sp"
                    app:layout_constraintBottom_toBottomOf="@id/ivSunset"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/ivSunset" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <GridLayout
            android:layout_width="368dp"
            android:layout_height="433dp"
            android:layout_marginTop="35dp"
            android:columnCount="2"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardGreeting">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTithi"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:backgroundTint="@android:color/white"
                android:paddingTop="20dp"
                android:paddingBottom="20dp"
                android:text="TITHI"
                android:textAllCaps="true"
                android:textColor="@android:color/black"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_tithi"
                app:iconGravity="textTop"
                app:iconPadding="8dp"

                app:iconSize="36dp"
                app:iconTint="@null"
                app:strokeColor="@color/saffron_dark"
                app:strokeWidth="1.5dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHorizons"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:backgroundTint="@android:color/white"
                android:paddingTop="20dp"
                android:paddingBottom="20dp"
                android:text="HORIZONS"
                android:textAllCaps="true"
                android:textColor="@android:color/black"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_horizons"
                app:iconGravity="textTop"
                app:iconPadding="8dp"

                app:iconSize="36dp"
                app:iconTint="@null"
                app:strokeColor="@color/saffron_dark"
                app:strokeWidth="1.5dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEvents"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:backgroundTint="@android:color/white"
                android:paddingTop="20dp"
                android:paddingBottom="20dp"
                android:text="EVENTS"
                android:textAllCaps="true"
                android:textColor="@android:color/black"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_events"
                app:iconGravity="textTop"
                app:iconPadding="8dp"

                app:iconSize="36dp"
                app:iconTint="@null"
                app:strokeColor="@color/saffron_dark"
                app:strokeWidth="1.5dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMonks"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:backgroundTint="@android:color/white"
                android:paddingTop="20dp"
                android:paddingBottom="20dp"
                android:text="MONKS"
                android:textAllCaps="true"
                android:textColor="@android:color/black"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_monks"
                app:iconGravity="textTop"
                app:iconPadding="8dp"

                app:iconSize="36dp"
                app:iconTint="@null"
                app:strokeColor="@color/saffron_dark"
                app:strokeWidth="1.5dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMe"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:backgroundTint="@android:color/white"
                android:paddingTop="20dp"
                android:paddingBottom="20dp"
                android:text="ME"
                android:textAllCaps="true"
                android:textColor="@android:color/black"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_me"
                app:iconGravity="textTop"
                app:iconPadding="8dp"

                app:iconSize="36dp"
                app:iconTint="@null"
                app:strokeColor="@color/saffron_dark"
                app:strokeWidth="1.5dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnContact"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:backgroundTint="@android:color/white"
                android:paddingTop="20dp"
                android:paddingBottom="20dp"
                android:text="CONTACT"
                android:textAllCaps="true"
                android:textColor="@android:color/black"
                android:textStyle="bold"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_contact"
                app:iconGravity="textTop"
                app:iconPadding="8dp"

                app:iconSize="36dp"
                app:iconTint="@null"
                app:strokeColor="@color/saffron_dark"
                app:strokeWidth="1.5dp" />
        </GridLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>