<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MaharajLocationActivity">

    <TextView
        android:id="@+id/textViewTithiTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📍 Upcoming Maharaj Locations"
        android:textSize="20sp"
        android:textStyle="bold"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <SearchView
        android:id="@+id/searchViewMaharaj"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:queryHint="Search name, city or location"
        app:layout_constraintTop_toBottomOf="@id/textViewTithiTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="16dp" />

    <Button
        android:id="@+id/buttonFilterMaharaj"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🔍 Filter"
        app:layout_constraintTop_toBottomOf="@id/searchViewMaharaj"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewMaharaj"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:contentDescription="Maharaj location list"
        app:layout_constraintTop_toBottomOf="@id/buttonFilterMaharaj"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"
        android:padding="8dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
