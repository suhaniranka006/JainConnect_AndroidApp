<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/main"
    android:background="@drawable/app_bg"
    tools:context=".ui.activities.MaharajLocationActivity">

    <!-- Gradient Header Background -->
    <View
        android:id="@+id/viewHeaderBg"
        android:layout_width="match_parent"
        android:layout_height="130dp"
        android:background="@drawable/bg_gradient_header"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Header Title -->
    <TextView
        android:id="@+id/textViewMaharajTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Monk Locations"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@android:color/white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="24dp"
        android:layout_marginTop="32dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Find Gurus near you."
        android:textSize="14sp"
        android:textColor="#DDFFFFFF"
        app:layout_constraintStart_toStartOf="@id/textViewMaharajTitle"
        app:layout_constraintTop_toBottomOf="@id/textViewMaharajTitle"/>

    <!-- Floating Search Bar -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardSearch"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@android:color/white"
        android:layout_marginHorizontal="24dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/viewHeaderBg"
        app:layout_constraintBottom_toBottomOf="@id/viewHeaderBg">

        <androidx.appcompat.widget.SearchView
            android:id="@+id/searchViewMaharaj"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:queryHint="Search Maharaj, City..."
            app:iconifiedByDefault="false"
            app:searchIcon="@drawable/ic_search"
            android:background="@android:color/transparent"/>
    </com.google.android.material.card.MaterialCardView>

    <!-- Filters horizontal scroll -->
    <HorizontalScrollView
        android:id="@+id/scrollFilters"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginTop="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardSearch">

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupFilters"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            app:selectionRequired="true"
            android:paddingHorizontal="24dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All"
                android:checkable="true"
                android:checked="true"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:textColor="@color/black"
                app:chipBackgroundColor="@color/white"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipOngoing"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ongoing"
                android:checkable="true"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:textColor="@color/black"
                app:chipBackgroundColor="@color/white"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipUpcoming"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Upcoming"
                android:checkable="true"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:textColor="@color/black"
                app:chipBackgroundColor="@color/white"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/chipNearMe"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Near Me (&lt;50km)"
                android:checkable="true"
                app:chipIcon="@drawable/ic_location"
                style="@style/Widget.MaterialComponents.Chip.Choice"
                android:textColor="@color/black"
                app:chipBackgroundColor="@color/white"/>

        </com.google.android.material.chip.ChipGroup>

    </HorizontalScrollView>
    <com.facebook.shimmer.ShimmerFrameLayout
        android:id="@+id/shimmerViewContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingHorizontal="12dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/scrollFilters"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <include layout="@layout/item_event_shimmer" />
            <include layout="@layout/item_event_shimmer" />
            <include layout="@layout/item_event_shimmer" />
            <include layout="@layout/item_event_shimmer" />
        </LinearLayout>
    </com.facebook.shimmer.ShimmerFrameLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewMaharaj"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingHorizontal="12dp"
        android:clipToPadding="false"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/scrollFilters"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddMaharaj"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:src="@android:drawable/ic_input_add"
        app:tint="@android:color/white"
        app:backgroundTint="#E64A19"
        app:elevation="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
