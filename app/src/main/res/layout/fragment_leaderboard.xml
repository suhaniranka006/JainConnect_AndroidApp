<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/saffron"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Leaderboard"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Podium Section (Top 3) -->
    <LinearLayout
        android:id="@+id/podiumLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="bottom|center_horizontal"
        android:paddingTop="24dp"
        android:paddingBottom="24dp"
        android:background="#FFF3E0"
        app:layout_constraintTop_toBottomOf="@id/headerLayout">

        <!-- Rank 2 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivSecondPlace"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:padding="2dp"
                app:strokeColor="#C0C0C0"
                app:strokeWidth="2dp"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.MediumComponent"
                app:srcCompat="@drawable/ic_profile_placeholder"/>
            <TextView
                android:id="@+id/tvSecondName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User 2"
                android:textStyle="bold"
                android:layout_marginTop="4dp"/>
            <TextView
                android:id="@+id/tvSecondScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1200"
                android:textColor="@color/saffron"/>
            <View
                android:layout_width="40dp"
                android:layout_height="60dp"
                android:background="#C0C0C0"
                android:layout_marginTop="4dp"/>
            <TextView
                android:text="2"
                android:textStyle="bold"
                android:layout_marginTop="-40dp"
                android:textColor="@android:color/white"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Rank 1 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginBottom="16dp"> <!-- Slightly higher -->
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_crown" 
                app:tint="#FFD700" 
                android:layout_marginBottom="-8dp"
                android:elevation="4dp"/>
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivFirstPlace"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:padding="2dp"
                app:strokeColor="#FFD700"
                app:strokeWidth="3dp"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.MediumComponent"
                app:srcCompat="@drawable/ic_profile_placeholder"/>
            <TextView
                android:id="@+id/tvFirstName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User 1"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginTop="4dp"/>
            <TextView
                android:id="@+id/tvFirstScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1500"
                android:textColor="@color/saffron"
                android:textStyle="bold"/>
            <View
                android:layout_width="50dp"
                android:layout_height="90dp"
                android:background="#FFD700"
                android:layout_marginTop="4dp"/>
             <TextView
                android:text="1"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginTop="-60dp"
                android:textColor="@android:color/white"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Rank 3 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
             <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivThirdPlace"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:padding="2dp"
                app:strokeColor="#CD7F32"
                app:strokeWidth="2dp"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.MediumComponent"
                app:srcCompat="@drawable/ic_profile_placeholder"/>
            <TextView
                android:id="@+id/tvThirdName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="User 3"
                android:textStyle="bold"
                android:layout_marginTop="4dp"/>
            <TextView
                android:id="@+id/tvThirdScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1000"
                android:textColor="@color/saffron"/>
            <View
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="#CD7F32"
                android:layout_marginTop="4dp"/>
              <TextView
                android:text="3"
                android:textStyle="bold"
                android:layout_marginTop="-30dp"
                android:textColor="@android:color/white"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/podiumLayout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvLeaderboard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/podiumLayout"
        app:layout_constraintBottom_toBottomOf="parent"
        android:paddingTop="8dp"
        android:clipToPadding="false"/>

</androidx.constraintlayout.widget.ConstraintLayout>
