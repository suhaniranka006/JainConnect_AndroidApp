<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/app_bg"
    tools:context=".ui.activities.TithiActivity">

    <TextView
        android:id="@+id/textViewTithiScreenTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TITHIS CHART"
        android:textSize="30sp"
        android:textStyle="bold"
        android:textColor="@color/bright_saffron"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="20dp"/>


    <androidx.appcompat.widget.SearchView
        android:id="@+id/searchViewTithi"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Search Tithi, date or description"
        android:iconifiedByDefault="false"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:clickable="true"

        android:background="@drawable/bg_edittext_rounded"

        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintTop_toBottomOf="@id/textViewTithiScreenTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="24dp"/>

    <LinearLayout
        android:id="@+id/linearLayoutFilterButtons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="20dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="20dp"
        app:layout_constraintTop_toBottomOf="@id/searchViewTithi"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:weightSum="3">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonShowAll"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Show All"
            android:layout_marginEnd="4dp"

            app:cornerRadius="16dp"
            android:textStyle="bold"
            android:backgroundTint="@color/bright_saffron"
            android:textColor="@color/text_on_saffron"
            app:strokeColor="@color/saffron"
            app:strokeWidth="1.5dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonNext7Days"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Next 7 Days"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="2dp"

            app:cornerRadius="16dp"
            android:textStyle="bold"
            android:backgroundTint="@color/bright_saffron"
            android:textColor="@color/text_on_saffron"
            app:strokeColor="@color/saffron"
            app:strokeWidth="1.5dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonNext15Days"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Next 15 Days"
            android:layout_marginStart="4dp"

            app:cornerRadius="16dp"
            android:textStyle="bold"
            android:backgroundTint="@color/bright_saffron"
            android:textColor="@color/text_on_saffron"
            app:strokeColor="@color/saffron"
            app:strokeWidth="1.5dp"/>
    </LinearLayout>


    <!-- Shimmer View Container -->
    <com.facebook.shimmer.ShimmerFrameLayout
        android:id="@+id/shimmerViewContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingHorizontal="12dp"
        android:paddingTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/linearLayoutFilterButtons"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <include layout="@layout/item_tithi_shimmer" />
            <include layout="@layout/item_tithi_shimmer" />
            <include layout="@layout/item_tithi_shimmer" />
            <include layout="@layout/item_tithi_shimmer" />
            <include layout="@layout/item_tithi_shimmer" />
            <include layout="@layout/item_tithi_shimmer" />
            <include layout="@layout/item_tithi_shimmer" />
        </LinearLayout>
    </com.facebook.shimmer.ShimmerFrameLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewTithi"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="20dp"
        android:paddingBottom="16dp"
        android:paddingHorizontal="12dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/linearLayoutFilterButtons"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_tithi"/>

</androidx.constraintlayout.widget.ConstraintLayout>
