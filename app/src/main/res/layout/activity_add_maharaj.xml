<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@android:color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp"
        tools:context=".ui.activities.AddMaharajActivity">

        <!-- Header Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add Monk Location"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="@color/jain_orange"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="16dp"/>

        <!-- Image Selection -->
        <FrameLayout
            android:id="@+id/flImageContainer"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/ivMaharajImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_launcher_background"
                android:scaleType="centerCrop"
                android:background="#E0E0E0"/>

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@android:drawable/ic_menu_camera"
                android:layout_gravity="center"
                android:alpha="0.5"/>
        </FrameLayout>

        <Button
            android:id="@+id/btnSelectImage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Photo (Small)"
            android:backgroundTint="@android:color/holo_blue_dark"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/flImageContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- 1. Monk Name Input -->
        <EditText
            android:id="@+id/etMaharajName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Maharaj Name (e.g., Acharya Shri...)"
            android:background="@android:drawable/edit_text"
            android:padding="12dp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/btnSelectImage"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- 2. Title Input -->
        <EditText
            android:id="@+id/etMaharajTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Title/Sect (e.g., Digamber)"
            android:background="@android:drawable/edit_text"
            android:padding="12dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/etMaharajName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- 3. Location Input -->
        <EditText
            android:id="@+id/etMaharajLocation"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Current Location (City/Temple)"
            android:background="@android:drawable/edit_text"
            android:padding="12dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/etMaharajTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- 4. Arrival Date Input -->
        <EditText
            android:id="@+id/etArrivalDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Arrival Date (YYYY-MM-DD)"
            android:inputType="date"
            android:background="@android:drawable/edit_text"
            android:padding="12dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/etMaharajLocation"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- 5. Vihar Date Input -->
        <EditText
            android:id="@+id/etViharDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Vihar Date (YYYY-MM-DD)"
            android:inputType="date"
            android:background="@android:drawable/edit_text"
            android:padding="12dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/etArrivalDate"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- 6. Description Input -->
        <EditText
            android:id="@+id/etDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Description (About Place/Event)"
            android:inputType="textMultiLine"
            android:lines="3"
            android:gravity="top|start"
            android:background="@android:drawable/edit_text"
            android:padding="12dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/etViharDate"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- 7. Contact Input -->
        <EditText
            android:id="@+id/etMaharajContact"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="Contact Number (Optional)"
            android:inputType="phone"
            android:background="@android:drawable/edit_text"
            android:padding="12dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/etDescription"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>



        <!-- Error Log Display -->
        <TextView
            android:id="@+id/tvErrorLog"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Error details will appear here..."
            android:textColor="@android:color/holo_red_dark"
            android:textSize="12sp"
            android:textIsSelectable="true"
            android:background="#10000000"
            android:padding="8dp"
            android:visibility="gone"
            android:layout_marginBottom="16dp"
            app:layout_constraintBottom_toTopOf="@+id/btnSubmitMaharaj"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Submit Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubmitMaharaj"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:text="Submit for Approval"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            app:backgroundTint="@color/jain_orange"
            app:cornerRadius="8dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="24dp"
            app:layout_constraintTop_toBottomOf="@id/etMaharajContact"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
