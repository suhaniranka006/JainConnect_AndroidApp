<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="@android:color/white"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top Section: Image + Details -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp">

            <!-- Maharaj Image (Left) -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivMaharajImage"
                android:layout_width="90dp"
                android:layout_height="90dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_launcher_background"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.MediumComponent"/>

            <!-- Details (Right) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    
                    <TextView
                        android:id="@+id/tvMaharajName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        tools:text="Acharya Shri Name"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:maxLines="1"
                        android:ellipsize="end"/>

                    <ImageView
                        android:id="@+id/btnSave"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:padding="6dp"
                        android:src="@drawable/ic_bookmark_border"
                        app:tint="#757575"
                        android:background="?attr/selectableItemBackgroundBorderless"/>
                </LinearLayout>

                <!-- Sampraday (Title) -->
                <TextView
                    android:id="@+id/tvMaharajSampraday"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    tools:text="Digambar Jain"
                    android:textSize="14sp"
                    android:textColor="#E64A19"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <!-- Location -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_location"
                        app:tint="#757575"/>
                    <TextView
                        android:id="@+id/tvMaharajCity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="Location/City"
                        android:textSize="14sp"
                        android:textColor="#616161"
                        android:layout_marginStart="6dp"
                        android:maxLines="1"
                        android:ellipsize="end"/>
                    

                </LinearLayout>

                <!-- Date -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">
                     <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_time" 
                        app:tint="#757575"/>
                    <TextView
                        android:id="@+id/tvMaharajDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="Relevant Date"
                        android:textSize="14sp"
                        android:textColor="#616161"
                         android:layout_marginStart="6dp"
                         android:maxLines="1"
                         android:ellipsize="end"/>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F5F5F5"/>

        <!-- Bottom Action -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp">

            <!-- Wrapper for Left Side (Distance + Contact) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Distance Section -->
                <LinearLayout
                    android:id="@+id/layoutDistanceContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginEnd="12dp"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_location"
                        app:tint="#E64A19"/>

                    <TextView
                        android:id="@+id/tvMaharajDistance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="5.2 km"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#E64A19"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>

                <!-- Contact with Icon -->
                <LinearLayout
                    android:id="@+id/layoutMaharajContact"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_call_filled"
                        app:tint="#424242"/>

                    <TextView
                        android:id="@+id/tvMaharajContact"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="+91 9876543210"
                        android:layout_marginStart="8dp"
                        android:textSize="14sp"
                        android:textColor="#424242"/>
                </LinearLayout>
            </LinearLayout>

             <!-- Explicit View Details Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewDetails"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="VIEW DETAILS"
                android:textSize="12sp"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:textColor="#E64A19"
                android:paddingHorizontal="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:layout_gravity="end"/>


        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
