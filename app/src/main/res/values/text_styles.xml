<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Text Appearance Styles -->
    <style name="TextAppearance.JainConnect.Headline1" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">32sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.01</item>
        <item name="android:textColor">@color/jain_maroon</item>
        <item name="fontFamily">@font/roboto_bold</item>
    </style>

    <style name="TextAppearance.JainConnect.Headline2" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="fontFamily">@font/roboto_medium</item>
    </style>

    <style name="TextAppearance.JainConnect.Headline3" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="fontFamily">@font/roboto_medium</item>
    </style>

    <style name="TextAppearance.JainConnect.Subtitle1" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="fontFamily">@font/roboto_medium</item>
    </style>

    <style name="TextAppearance.JainConnect.Body1" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">16sp</item>
        <item name="android:lineSpacingMultiplier">1.3</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="fontFamily">@font/roboto_regular</item>
    </style>

    <style name="TextAppearance.JainConnect.Body2" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingMultiplier">1.3</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="fontFamily">@font/roboto_regular</item>
    </style>

    <style name="TextAppearance.JainConnect.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_hint</item>
        <item name="fontFamily">@font/roboto_regular</item>
    </style>

    <style name="TextAppearance.JainConnect.Button" parent="TextAppearance.MaterialComponents.Button">
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="fontFamily">@font/roboto_medium</item>
    </style>
</resources>
