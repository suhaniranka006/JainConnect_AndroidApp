<resources>
    <!-- Base application theme -->
    <!-- FIX YAHAN HAI: Humne "Material3" ko "MaterialComponents" se badal diya hai. Yeh aapke androidx.appcompat.widget.SearchView ke saath sahi se kaam karega. -->
    <style name="Base.Theme.JainConnect" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/saffron_dark</item>
        <item name="colorPrimaryVariant">@color/saffron_light</item>
        <item name="colorOnPrimary">@color/text_on_saffron</item>
        <item name="android:windowBackground">@android:color/white</item>
        <!-- system default bg -->
    </style>

    <style name="ProfileTextView">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">18sp</item>
        <item name="android:padding">12dp</item>
        <item name="android:background">#f0f0f0</item>
        <item name="android:layout_marginBottom">8dp</item>
    </style>

    <!-- Main app theme -->
    <style name="Theme.JainConnect" parent="Base.Theme.JainConnect" />
</resources>
