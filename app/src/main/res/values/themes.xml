<resources>
    <!-- Base application theme -->
    <!-- FIX YAHAN HAI: Humne "Material3" ko "MaterialComponents" se badal diya hai. Yeh aapke androidx.appcompat.widget.SearchView ke saath sahi se kaam karega. -->
    <style name="Base.Theme.JainConnect" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/bright_saffron</item>
        <item name="colorPrimaryVariant">@color/dark_charcoal</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:windowBackground">@drawable/app_bg</item>
        <!-- system default bg -->
    </style>

    <style name="ProfileTextView">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">18sp</item>
        <item name="android:padding">12dp</item>
        <item name="android:background">#f0f0f0</item>
        <item name="android:layout_marginBottom">8dp</item>
    </style>

    <!-- Main app theme -->
    <style name="Theme.JainConnect" parent="Base.Theme.JainConnect" />
    <style name="Theme.JainConnect.NoActionBar" parent="Theme.JainConnect" />

    <style name="RoundedImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <!-- NEW UNIQUE SHAPE FOR QUICK ACTIONS -->
    <style name="ShapeAppearance.JainConnect.QuickAction" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
    <!-- Glassmorphism Card Style -->
    <style name="Widget.JainConnect.GlassCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">#CCFFFFFF</item> <!-- 80% White transparent -->
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">#80FFFFFF</item> <!-- 50% White border -->
        <item name="android:layout_margin">8dp</item>
    </style>
</resources>
