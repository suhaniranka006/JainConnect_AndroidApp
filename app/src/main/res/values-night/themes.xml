<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme for Dark Mode -->
    <!-- This file is auto-selected by Android when in Dark Mode -->
    <style name="Base.Theme.JainConnect" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- In dark mode, a lighter primary often looks better -->
        <item name="colorPrimary">@color/saffron_light</item>
        <item name="colorPrimaryVariant">@color/saffron</item>
        <item name="colorOnPrimary">@color/text_on_saffron</item> <!-- Still black, as it's on saffron -->

        <!-- FIXED: Added status bar color for dark mode -->
        <item name="android:statusBarColor">@color/saffron</item>

        <!-- Key Dark Mode Overrides -->
        <item name="android:windowBackground">@color/app_background_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/text_on_dark</item> <!-- Text on backgrounds/surfaces -->
        <item name="android:textColor">@color/text_on_dark</item> <!-- Default text color -->

        <!-- FIXED: Tell the theme to use our new secondary color for hints -->
        <item name="android:textColorHint">@color/text_on_dark_secondary</item>
    </style>

    <!-- Dark Mode override for ProfileTextView -->
    <style name="ProfileTextView">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">18sp</item>
        <item name="android:padding">12dp</item>
        <item name="android:background">@color/surface_dark</item> <!-- Use dark surface color -->
        <item name="android:textColor">@color/text_on_dark</item> <!-- Use light text color -->
        <item name="android:layout_marginBottom">8dp</item>
    </style>

    <!-- Main app theme (inherits from Base) -->
    <style name="Theme.JainConnect" parent="Base.Theme.JainConnect" />

</resources>


