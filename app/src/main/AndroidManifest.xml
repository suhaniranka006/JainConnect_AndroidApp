<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.mycompany.jainconnect">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <application
        android:name=".JainConnectApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/jainconnect_app_logo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/jainconnect_app_logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.JainConnect"
        android:usesCleartextTraffic="false"
        tools:targetApi="31">
        <activity
            android:name=".ui.activities.AddMaharajActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.AddEventActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.HorizonsActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.ContactActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.MaterialComponents.Light.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".ui.activities.SignUpActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.LoginActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.EditProfileActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.MaharajLocationActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.EventActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.TithiActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.BhojanshalaActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.AddBhojanshalaActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.CarpoolActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.AddCarpoolActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".ui.activities.CreateYatraActivity"
            android:exported="false"
            android:theme="@style/Theme.JainConnect.NoActionBar" />
        <activity
            android:name=".ui.activities.TirthyatraDetailsActivity"
            android:exported="false"
            android:theme="@style/Theme.JainConnect.NoActionBar" />
        <activity
            android:name=".ui.activities.TirthyatraActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.MaterialComponents.Light.NoActionBar" />
        <activity
            android:name=".ui.activities.LegacyActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".ui.activities.StoryDetailActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.MaterialComponents.Light.NoActionBar"/>
        <activity
            android:name=".ui.activities.TempleActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.AddTempleActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.MainActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false" /> <!-- Yeh 'false' sahi hai, kyunki Splash se open ho rahi hai -->
        <activity
            android:name=".ui.activities.ProfileActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.PachkhanActivity"
            android:exported="false" />
        <activity
            android:name=".ui.activities.MembersActivity"
            android:exported="false" />

    </application>

</manifest>
